# 汉坦观察 (HantaWatch) 环境变量
# 复制此文件为 .env.local 并修改

# 站点 URL
NEXT_PUBLIC_SITE_URL=https://bingduguancha.com

# 管理员密钥 (用于 /admin 和 /api/feedback/list)
ADMIN_KEY=admin_key_2026

# Supabase (订阅邮箱持久化；未设置时 subscribe API 会降级为只打印日志)
# 在 https://supabase.com 创建项目，找到 Project Settings → API
# - SUPABASE_URL 是 Project URL
# - SUPABASE_SERVICE_ROLE_KEY 是 service_role 密钥（注意：永远不能暴露到浏览器）
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Redis (可选，用于缓存和限流)
# REDIS_URL=redis://localhost:6379

# PostgreSQL (可选，自托管时用)
# DATABASE_URL=postgres://hantawatch:hantawatch_dev@localhost:5432/hantawatch

# Sentry (可选，错误监控)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# 邮件服务 (可选，用于预警推送)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass

# ---- 实时动态 ----
# 配置 LLM_API_KEY 后，services/collector 会抓取实时数据源，按时间线提
# 取条目，调用 LLM 生成中文摘要 + 关键事实标签。未配置时实时动态区块
# 展示「暂无数据」空态。
#
# 默认走 DeepSeek（OpenAI 兼容）。更换其他模型只需改 LLM_API_BASE_URL +
# LLM_MODEL，无需改代码。
#
# 复制到 .env.local 后，取消注释 LLM_API_KEY 并填入你的实际 key 即可：
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
#
# 下面三项保持默认即可，仅当你切换到其他 OpenAI 兼容供应商时再覆盖：
# LLM_API_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash
# LLM_THINKING=disabled
#
# REALTIME_FEED_URL：默认走 Hantaflow 的英文 signals endpoint（聚合
# WHO/CDC/ECDC/PAHO + 英文新闻，CC BY 4.0，国内可访问）。可选 endpoint：
#   英文（默认，推荐）：   https://hantaflow.com/api/languages/en.json
#   全语种（17 种）：      https://hantaflow.com/api/signals.json
#   单国家：               https://hantaflow.com/api/countries/<slug>.json
#                          slug 同 hantaflow 国家页面的 URL，例如
#                          united-states、argentina、germany、russia
#   单语种：               https://hantaflow.com/api/languages/<lang>.json
#                          lang ∈ {en, es, de, fr, pt, it, tr, el, ru,
#                                  pl, ko, zh, fi, sv, nl, id, vi}
# REALTIME_FEED_URL=https://hantaflow.com/api/languages/en.json

# REALTIME_MIN_STRENGTH：信号强度过滤阈值。LLM 会给每条新闻打分
# high/medium/low（high=官方通报+具体数字，medium=国家级声明+研究进
# 展，low=评论/历史/社交媒体梗）。
#   - high   严格，只留 high；约 3-8 条/次
#   - medium 默认，留 high + medium；约 10-15 条/次
#   - low    全部保留（调试用，能看到 LLM 判低的都长什么样）
# REALTIME_MIN_STRENGTH=medium
