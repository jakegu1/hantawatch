# 汉坦观察 (HantaWatch) 环境变量
# 复制此文件为 .env.local 并修改

# 站点 URL
NEXT_PUBLIC_SITE_URL=https://hantawatch.cn

# 管理员密钥 (用于 /admin 和 /api/feedback/list)
ADMIN_KEY=admin_key_2026

# Supabase (订阅邮箱持久化；未设置时 subscribe API 会降级为只打印日志)
# 在 https://supabase.com 创建项目，找到 Project Settings → API
# - SUPABASE_URL 是 Project URL
# - SUPABASE_SERVICE_ROLE_KEY 是 service_role 密钥（注意：永远不能暴露到浏览器）
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Redis (可选，用于缓存和限流)
# REDIS_URL=redis://localhost:6379

# PostgreSQL (可选，自托管时用)
# DATABASE_URL=postgres://hantawatch:hantawatch_dev@localhost:5432/hantawatch

# Sentry (可选，错误监控)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# 邮件服务 (可选，用于预警推送)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass
